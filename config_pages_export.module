<?php

/**
 * @file
 * Contains hooks and functions for the config_pages_export module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function config_pages_export_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.config_pages_export') {
    $output = '<h3>' . t('About') . '</h3>';
    $output .= '<p>' . t('The Config Pages Export module provides functionality to export and import config_pages content entities between environments.') . '</p>';
    $output .= '<h3>' . t('Usage') . '</h3>';
    $output .= '<p>' . t('Export: Use <code>drush cpex</code> to export all config pages to a file.') . '</p>';
    $output .= '<p>' . t('Import: Use <code>drush cpim</code> to import config pages from the exported file.') . '</p>';
    $output .= '<p>' . t('Deployment: Run <code>drush updb</code> to automatically import config pages during deployments.') . '</p>';
    return $output;
  }
}
